# CodeLeash Environment Configuration
# For local development, run ./init.sh to auto-configure Supabase settings.

# Application Settings
ENVIRONMENT=development

# Supabase Configuration (auto-configured by init.sh for local dev)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# JWT Configuration (auto-configured by init.sh for local dev)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# OpenTelemetry Configuration (Optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_HONEYCOMB_API_KEY
# OTEL_SERVICE_NAME=codeleash

# Sentry Configuration (Optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
