{
  "entry": ["src/roots/*.tsx", "src/main.ts", "src/app.ts"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "dist/**",
    "node_modules/**",
    "src/types/initial-data.ts",
    "src/**/*.test.{ts,tsx}"
  ],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@types/*",
    "json-schema-to-typescript",
    "magic-string",
    "@testing-library/*",
    "@vitest/*"
  ],
  "ignoreBinaries": ["patch", "pkill", "tsc", "uv"],
  "vitest": false,
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "unlisted": "warn",
    "exports": "error"
  }
}
