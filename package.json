{
  "name": "codeleash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "init": "./init.sh",
    "dev": "dotenv -- sh -c 'concurrently -n vite,uvicorn,worker vite \"uv run python main.py\" \"uv run python worker.py\"'",
    "build": "vite build",
    "lint": "eslint . --max-warnings 0 --cache",
    "lint:fix": "eslint . --fix --cache",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:python": "uv run pytest tests/ --ignore=tests/e2e",
    "test:all": "concurrently --kill-others-on-fail 'npm run pre-commit' 'npm test' 'npm run test:python' 'npm run test:e2e'",
    "test:e2e": "uv run python scripts/run_e2e_tests.py",
    "test:e2e:serial": "uv run python scripts/run_e2e_tests.py --serial",
    "test:e2e:parallel:4": "uv run python scripts/run_e2e_tests.py -n 4",
    "test:e2e:browser": "uv run python scripts/run_e2e_tests.py --headed",
    "test:e2e:ui": "uv run pytest tests/e2e/ -v",
    "test:e2e:debug": "uv run pytest tests/e2e/ -v -s",
    "pre-commit": "uv run prek run --all-files -q",
    "types": "uv run python scripts/generate_types.py",
    "docs": "make -C docs html",
    "docs:clean": "make -C docs clean",
    "site": "npm run docs && mkdir -p _site/docs && cp site/index.html _site/ && cp docs/build/* _site/docs/"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "globals": "^16.3.0",
    "json-schema-to-typescript": "^15.0.0",
    "jsdom": "^26.1.0",
    "magic-string": "^0.30.17",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.0.3",
    "vitest": "^3.2.4"
  }
}
